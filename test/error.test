test qc::error_report_locals-1 \
    {} \
    -setup $setup \
    -cleanup $cleanup \
    -body {
        proc test_proc {} {
            set var1 "value1" 
            set var2 [string repeat "value2" 500] 
            return [qc::error_report_locals]
        }
        return [test_proc]
    } \
    -match glob \
    -result {*<b>var1</b>*}

